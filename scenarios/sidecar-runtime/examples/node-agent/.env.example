# Agent Assembly sidecar connection settings
# Copy to .env and fill in your values, or export variables in your shell.

# Address of the local Agent Assembly core (from docker compose) that the
# SDK client connects to. The agent passes this to init_assembly; it never
# calls the gateway directly. Leave unset to run in offline mode without Docker.
# ASSEMBLY_GATEWAY_URL=http://localhost:8080

# Optional: agent identity (required for the real gateway)
# ASSEMBLY_API_KEY=your-api-key-here
# ASSEMBLY_AGENT_ID=your-agent-id-here
